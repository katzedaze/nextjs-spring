POSTGRES_DB=todoapp
POSTGRES_USER=todoapp
POSTGRES_PASSWORD=change-me-in-prod

BACKEND_PORT=8080
FRONTEND_PORT=3000

JWT_SECRET=please-change-me-to-a-long-random-string-at-least-32-bytes
JWT_EXPIRATION_MS=3600000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_INTERNAL_BASE_URL=http://backend:8080

