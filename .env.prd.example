# PRD profile. Copy to `.env.prd` and populate real values
# (typically from a secret manager / CI). Activated by `make up-prd`.
#
# NEVER commit `.env.prd` — only this `.example` template is tracked.

APP_ENV=prd

POSTGRES_DB=todoapp
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME

BACKEND_PORT=8080
FRONTEND_PORT=3000

# >=32 bytes; rotate per environment. Load from a secret manager in CI/CD.
JWT_SECRET=REPLACE_ME_WITH_PRD_SECRET_AT_LEAST_32_BYTES
# Shorter expiry for production.
JWT_EXPIRATION_MS=900000

NEXT_PUBLIC_API_BASE_URL=https://api.example.com
API_INTERNAL_BASE_URL=http://backend:8080

# Comma-separated list of origins allowed to call the backend.
APP_CORS_ALLOWED_ORIGINS=https://app.example.com

# Must be 0 (or unset) — production is always HTTPS.
COOKIE_INSECURE=0
LOG_LEVEL=warn
