# DEV (local) profile template. `make init-dev` copies this to `.env.dev`.
# Also serves as the base template for CI.
#
# For STG / PRD use `.env.stg.example` / `.env.prd.example` as the templates
# and run `make up-stg` / `make up-prd` (passes `--env-file` to docker compose).
# See README "環境 (DEV / STG / PRD)" section.

APP_ENV=dev

POSTGRES_DB=todoapp
POSTGRES_USER=todoapp
POSTGRES_PASSWORD=change-me-in-prod

BACKEND_PORT=8080
FRONTEND_PORT=3000

JWT_SECRET=please-change-me-to-a-long-random-string-at-least-32-bytes
JWT_EXPIRATION_MS=3600000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_INTERNAL_BASE_URL=http://backend:8080

# Set to "1" to opt out of the Secure cookie flag for local HTTP development.
# Honored only when APP_ENV=dev; ignored in stg/prd (cookies are always Secure).
COOKIE_INSECURE=1

# pino log level for the Next.js server-side logger.
LOG_LEVEL=debug
